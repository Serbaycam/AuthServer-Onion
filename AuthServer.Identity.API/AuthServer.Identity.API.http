@AuthServer.Identity.API_HostAddress = https://localhost:7023

# ==========================================
# 1. GÝRÝŢ & TOKEN ÝŢLEMLERÝ
# ==========================================

# @name Login
POST {{AuthServer.Identity.API_HostAddress}}/api/auth/login
Accept: application/json
Content-Type: application/json

{
  "email": "superadmin@AuthServer.local",
  "password": "Pa$$word123!"
}

###

# Login isteđinden dönen "accessToken" deđerini buraya yapýţtýrýn.
# Diđer tüm istekler bu deđiţkeni kullanacak.
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..7FBrlIn-xZ6a05Ejjq1xtYNMb96q8jxXXRIR-aTgI4U

### 

# Yönetici Tarafýndan Yeni Kullanýcý Oluţturma
POST {{AuthServer.Identity.API_HostAddress}}/api/UserManagement/create-user
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "Ahmet",
  "lastName": "Yilmaz",
  "email": "ahmet@lab.local",
  "password": "NewUser123!",
  "roles": ["Basic", "LabTechnician"]
}

###

# Kullanýcý Ţifresini Deđiţtirme (Force Reset)
# userId kýsmýna ţifresini deđiţtireceđin kullanýcýnýn ID'sini yaz.
POST {{AuthServer.Identity.API_HostAddress}}/api/UserManagement/change-password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "487ec7e6-5100-4418-8c3b-08de9ea2d416",
  "newPassword": "ResetPa$$123"
}
###
# Kullanýcý Bilgilerini Güncelle (Ad, Soyad, Email)
# userId: Güncellenecek kiţinin ID'si
PUT {{AuthServer.Identity.API_HostAddress}}/api/UserManagement/update-user
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "487ec7e6-5100-4418-8c3b-08de9ea2d416",
  "firstName": "Mehmet",
  "lastName": "Demir",
  "email": "mehmet.yeni@lab.local"
}